# Supabase — find these under Project Settings > API Keys
# NEXT_PUBLIC_* variables are exposed to the browser
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key — BYPASSES Row Level Security
# Required only for running supabase/seed.ts locally
# Never commit this key, never expose to the client, never put in NEXT_PUBLIC_*
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Your deployment URL — used for magic link redirect
# Local: http://localhost:3000
# Production: https://your-deployment.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
