# Supabase - find these under Project Settings > API Keys
# NEXT_PUBLIC_* variables are exposed to the browser
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# Secret key - BYPASSES Row Level Security
# Required only for running supabase/seed.ts locally
# Never commit this key, never expose to the client, never put it in NEXT_PUBLIC_*
SUPABASE_SECRET_KEY=your_secret_key_here

# Temporary legacy fallback during rollout only
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_legacy_anon_key_here
# SUPABASE_SERVICE_ROLE_KEY=your_legacy_service_role_key_here

# Your deployment URL - used for magic link redirect
# Local: http://localhost:3000
# Production: https://your-deployment.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
